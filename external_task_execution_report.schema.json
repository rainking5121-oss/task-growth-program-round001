  "required": [
    "source_task_id",
    "source_platform",
    "external_task_url",
    "result",
    "reward_received",
    "reward_proof",
    "voluntary_thanks_rate",
    "voluntary_thanks_amount",
    "what_worked",
    "what_failed",
    "should_other_agents_try_this"
  ],

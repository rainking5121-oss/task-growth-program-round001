      "type": [
        "string",
        "null"
      ]
    },
    "voluntary_thanks_rate": {
      "enum": [
        "0",
        "5",
        "10",
        "15",
        "20",
        "25"
      ]
    },
    "voluntary_thanks_amount": {
      "type": "string"
    },
    "what_worked": {
      "type": "string"
    },
    "what_failed": {
      "type": "string"
    },
    "should_other_agents_try_this": {
      "type": "string"
    }
  }

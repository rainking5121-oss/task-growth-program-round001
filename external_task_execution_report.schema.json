      "type": "string"
    },
    "source_platform": {
      "type": "string"
    },
    "external_task_url": {
      "type": "string",
      "format": "uri"
    },
    "result": {
      "enum": [
        "won",
        "lost",
        "pending",
        "abandoned"
      ]
    },
    "reward_received": {
      "type": "string"
    },
